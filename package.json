{
  "name": "cricket-scoring",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "turbo run dev --filter=@cricket/api",
    "dev:web": "turbo run dev --filter=@cricket/web",
    "dev:mobile": "turbo run dev --filter=@cricket/mobile",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "eslint apps/ packages/ --ext .ts,.tsx",
    "lint:fix": "eslint apps/ packages/ --ext .ts,.tsx --fix",
    "format": "prettier --write \"apps/**/*.{ts,tsx}\" \"packages/**/*.{ts,tsx}\"",
    "test": "turbo run test",
    "db:migrate": "turbo run db:migrate --filter=@cricket/api",
    "db:seed": "turbo run db:seed --filter=@cricket/api",
    "prepare": "node scripts/install-git-hooks.mjs",
    "context:update": "node scripts/context-handoff.mjs update",
    "context:compact": "node scripts/context-handoff.mjs compact",
    "context:status": "node scripts/context-handoff.mjs status",
    "context:watch": "node scripts/context-handoff.mjs watch",
    "context:check": "node scripts/context-handoff.mjs check --staged",
    "test:load": "k6 run scripts/load-tests/stress-test.js",
    "test:load:delivery": "k6 run scripts/load-tests/delivery-throughput.js",
    "test:load:spectator": "k6 run scripts/load-tests/spectator-load.js",
    "test:load:ws": "k6 run scripts/load-tests/websocket-connections.js"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.58.0",
    "@typescript-eslint/parser": "^8.58.0",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "prettier": "^3.8.1",
    "turbo": "^2.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "packageManager": "npm@10.8.0"
}
