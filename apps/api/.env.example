# ─── Database (TimescaleDB) ──────────────────────────────────────────────────
DATABASE_URL=postgres://cricket:cricket_dev@localhost:5433/cricket_scoring
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=20
DB_CONNECT_TIMEOUT=10

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate secrets with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-me-generate-a-real-secret
JWT_REFRESH_SECRET=change-me-generate-a-real-refresh-secret
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY_DAYS=7

# ─── Server ──────────────────────────────────────────────────────────────────
PORT=3001
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=info

# ─── CORS (comma-separated origins for production) ──────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Email (SMTP) ───────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM=CricScore <noreply@cricscore.app>
APP_URL=http://localhost:5173

# ─── Storage (S3/R2 — optional, falls back to local disk) ───────────────────
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_CDN_URL=

# ─── Feature Flags ──────────────────────────────────────────────────────────
FEATURE_FANTASY=false
FEATURE_CHAT=true
FEATURE_NOTIFICATIONS=true
FEATURE_LEADERBOARDS=true
